{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schemas/schema_contrasts.json",
    "title": "nf-core/differentialabundance pipeline - params.contrasts schema",
    "description": "Schema for the file provided with params.contrasts",
    "anyOf": [
        {
            "type": "array",
            "items": {
                "anyOf": [
                    {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "variable": {
                                "type": "string"
                            },
                            "reference": {
                                "type": "string"
                            },
                            "target": {
                                "type": "string"
                            },
                            "blocking": {
                                "type": "string"
                            }
                        },
                        "required": ["id", "variable", "reference", "target"]
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "minItems": 4
                    }
                ]
            },
            "minItems": 1
        },
        {
            "type": "object",
            "properties": {
                "contrasts": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "formula": {
                                "type": "string",
                                "pattern": "^~\\s*(?:(?:[A-Za-z0-9_.]+(?:\\([^)]*\\))?|\\([^)]*\\))(?:\\s*[+*:|\\/-]\\s*(?:[A-Za-z0-9_.]+(?:\\([^)]*\\))?|\\([^)]*\\)))*)?(?:\\s*-\\s*1)?$"
                            },
                            "comparison": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "minItems": 3
                            },
                            "blocking_factors": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "minItems": 1,
                                "uniqueItems": true
                            },
                            "make_contrasts_str": {
                                "type": "string"
                            }
                        },
                        "required": ["id"],
                        "additionalProperties": false
                    },
                    "minItems": 1
                },
                "variables": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": ["string", "integer", "number", "numeric"]
                            },
                            "description": {
                                "type": "string"
                            },
                            "enum": {
                                "type": "array",
                                "items": {
                                    "type": ["string", "number", "integer"]
                                },
                                "minItems": 1,
                                "uniqueItems": true
                            },
                            "minimum": {
                                "type": "number"
                            }
                        },
                        "additionalProperties": false
                    }
                }
            },
            "required": ["contrasts"],
            "additionalProperties": false
        }
    ]
}
