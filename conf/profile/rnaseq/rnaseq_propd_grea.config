/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    RNA-seq propd + grea analysis profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Inherits from rnaseq_propd.config and adds grea functional enrichment, which consumes
    the adjacency matrix emitted by propd.
----------------------------------------------------------------------------------------
*/

includeConfig 'rnaseq_propd.config'

params {
    paramset_name        = 'rnaseq_propd_grea'
    functional_method    = 'grea'
    // grea consumes propd's adjacency matrix, so persist it from propd
    propd_save_adjacency = true
}
