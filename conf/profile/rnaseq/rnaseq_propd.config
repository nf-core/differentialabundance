/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    RNA-seq propd analysis profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Inherits RNA-seq base settings from rnaseq.config and overrides with propd-specific
    differential analysis parameters (differential proportionality, normalization-free).
----------------------------------------------------------------------------------------
*/

includeConfig 'rnaseq.config'

params {
    paramset_name            = 'rnaseq_propd'

    // Differential analysis (propd)
    differential_method      = 'propd'

    // propd does not produce a normalised matrix; only the raw assay is meaningful downstream
    exploratory_assay_names  = 'raw'
    exploratory_final_assay  = 'raw'
    exploratory_log2_assays  = null

    // Differential output columns produced by propd.R
    differential_file_suffix = '.propd.genewise.tsv'
    differential_fc_column   = 'LFC'
    differential_pval_column = 'rcDdis'
    differential_qval_column = 'rcDdis'
}
