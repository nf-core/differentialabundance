/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running SOFT tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and overrides for a minimal SOFT test profile.

    Use as follows:
        nextflow run nf-core/differentialabundance -profile soft,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

includeConfig '../../profile/soft/soft.config'
includeConfig '../../testdata/soft.config'

params {
    config_profile_name        = 'Test soft profile'
    config_profile_description = 'SOFT test dataset to check pipeline function'
    round_digits               = 4
}
