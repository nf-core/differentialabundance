/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running generic_matrix dream tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and overrides for a generic_matrix + dream test profile with complex formula.

    Use as follows:
        nextflow run nf-core/differentialabundance -profile generic_matrix_dream,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

includeConfig '../../profile/generic_matrix/generic_matrix_dream.config'
includeConfig '../../testdata/rnaseq_complex.config'

params {
    // Reuse RNA-seq-derived feature metadata generated from the test GTF
    features_id_col = 'gene_id'
    features_name_col = 'gene_name'
    features_metadata_cols = 'gene_id,gene_name'
    differential_feature_id_column = 'gene_id'

    // Exploratory
    exploratory_main_variable = 'contrasts'

    // Apply a higher filter to check that the filtering works
    filtering_min_abundance = 10

    // Report options
    report_contributors = 'Jane Doe\nDirector of Institute of Microbiology\nUniversity of Smallville;John Smith\nPhD student\nInstitute of Microbiology\nUniversity of Smallville'

    // Other
    round_digits = 3
}
