/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for stabilising MaxQuant nf-tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    The MaxQuant limma test output contains values close to rounding boundaries.
    Force single-threaded linear algebra in this test profile so CI and local
    runs use the same implicit math backend behaviour.
----------------------------------------------------------------------------------------
*/

env {
    OPENBLAS_NUM_THREADS   = '1'
    OMP_NUM_THREADS        = '1'
    MKL_NUM_THREADS        = '1'
    BLIS_NUM_THREADS       = '1'
    VECLIB_MAXIMUM_THREADS = '1'
    NUMEXPR_NUM_THREADS    = '1'
}

process {
    withName: LIMMA_DIFFERENTIAL {
        cpus = 1
    }

    withName: LIMMA_NORM {
        cpus = 1
    }
}
