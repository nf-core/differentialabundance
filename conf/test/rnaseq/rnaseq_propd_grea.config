/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running RNA-seq propd + grea tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and overrides for a RNA-seq propd + grea test profile.

    Use as follows:
        nextflow run nf-core/differentialabundance -profile test_rnaseq_propd_grea,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

includeConfig '../../profile/rnaseq/rnaseq_propd_grea.config'
includeConfig '../../testdata/rnaseq.config'

params {
    // The shared RNA-seq test gmt uses gene symbols, but propd / grea operate
    // on the abundance matrix's Ensembl gene IDs, so swap in an Ensembl-ID
    // gmt added to the nf-core/test-datasets `differentialabundance` branch
    // for this purpose. TODO: flip URL back to `refs/heads/differentialabundance`
    // once nf-core/test-datasets#2050 merges.
    gene_sets_files = 'https://raw.githubusercontent.com/pinin4fjords/test-datasets/refs/heads/add-propd-grea-test-gmt/testdata/SRP254919.propd_grea_test_sets.gmt'

    // Exploratory
    exploratory_main_variable = 'contrasts'

    // Apply a higher filter to check that the filtering works
    filtering_min_abundance = 10

    // rcDdis is bounded [0,1]; keep filter thresholds permissive so rows reach the report
    differential_max_pval        = 1
    differential_max_qval        = 1
    differential_min_fold_change = 1.5

    // Use the analytical FDR rather than the slow permutation-based one for CI
    propd_permutation = 0

    // Test gmt is small; shrink set_min and permutation count for runtime
    grea_set_min      = 5
    grea_permutation  = 50

    // Report options
    report_contributors = 'Jane Doe\nDirector of Institute of Microbiology\nUniversity of Smallville;John Smith\nPhD student\nInstitute of Microbiology\nUniversity of Smallville'

    // Other
    round_digits = 3
    seed         = 10
}

// grea defaults to process_high (72 GB) which exceeds the CI runner; the
// small test gmt + adjacency only need a few hundred MB
process {
    withName: PROPR_GREA {
        memory = { 6.GB * task.attempt }
    }
}
