nextflow_pipeline {

    name "Test Workflow main.nf - DIFFERENTIALABUNDANCE (dream)"
    script "../main.nf"
    tag "rnaseq_dream"
    tag "pipeline"

    test("Test rnaseq dream profile") {
        config "${projectDir}/conf/test/rnaseq/rnaseq_dream_complex.config"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            // debug_table_heads: Header + first five rows for TSVs prone to CI/local drift
            def output_root = new File(params.outdir.toString())
            def debug_table_heads = []
            output_root.eachFileRecurse { file ->
                if (file.isFile() && (
                    file.name ==~ /.*\.(limma|dream)\.(results|results_filtered|annotated)\.tsv$/ ||
                    file.name ==~ /.*normalised_counts\.tsv$/ ||
                    file.name ==~ /.*proteingroups_tab\.tsv$/
                )) {
                    def relative_path = output_root.toPath().relativize(file.toPath()).toString()
                    debug_table_heads << [(relative_path): file.readLines().take(6)]
                }
            }
            debug_table_heads = debug_table_heads.sort { it.keySet().first() }
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we tests pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_differentialabundance_software_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path,
                    // Lightweight table content previews to diagnose CI-only md5 drift
                    debug_table_heads
                ).match() }
                )
        }
    }

    test("Test rnaseq dream profile - complex contrast - with zero intercept - 1") {
        config "${projectDir}/conf/test/rnaseq/rnaseq_dream_complex.config"

        when {
            params {
                outdir = "$outputDir"

                // Override contrasts for zero intercept test
                contrasts = "${projectDir}/tests/assets/zero_intercept_contrasts_1.yml"

                // DREAM without voom (dream_norm paramset)
                dream_apply_voom        = false
                exploratory_assay_names = 'raw'
                exploratory_final_assay = 'raw'

            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
