            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we tests pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_differentialabundance_software_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
                )
        }
    }

    test("Test - Numeric sample IDs - deseq2_rnaseq_gsea") {
        config "${projectDir}/conf/rnaseq/rnaseq_deseq2_gsea.config"

        when {
            params {
                outdir = "$outputDir"

                // Input data (rnaseq_testdata_numeric_samples - local files with numeric sample IDs)
                study_name            = 'SRP254919'
                input                 = "${projectDir}/tests/assets/SRP254919.samplesheet.csv"
                matrix                = "${projectDir}/tests/assets/SRP254919.salmon.merged.gene_counts.top1000cov.tsv"
